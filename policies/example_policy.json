{
  "name": "example_policy",
  "identifiers": {
    "person": {
      "removePunctuation": false,
      "thresholds": {},
      "phEyeConfiguration": {
        "endpoint": "http://philter-ph-eye-en-1:5000",
        "timeout": 600,
        "maxIdleConnections": 30,
        "labels": [
          "Person"
        ]
      }
    },
    "age": {
      "ageFilterStrategies": [
        {
          "filterType": "AGE",
          "strategy": "REDACT",
          "redactionFormat": "{{{REDACTED-%t}}}"
        }
      ]
    },
    "identifiers": [
      {
        "patientIds": [
          {
            "pattern": "^\\d{9}$",
            "identifierFilterStrategies": [
              {
                "filterType": "IDENTIFIER",
                "strategy": "REDACT",
                "redactionFormat": "{{{REDACTED-%t}}}"
              }
            ]
          }
        ]
      }
    ],
    "ssn": {
      "ssnFilterStrategies": [
        {
          "filterType": "SSN",
          "strategy": "REDACT",
          "redactionFormat": "{{{REDACTED-%t}}}"
        }
      ]
    }
  }
}